# Environment variable template for the Framer Motion Score Float Effect Demo.
#
# Copy this file to `.env` (or `.env.local`) and adjust values as needed.
# `.env*` files (except this example) are gitignored and never committed.
#
# IMPORTANT: Vite only exposes variables prefixed with `VITE_` to client code.
# Any variable without the `VITE_` prefix is available only at build/dev time
# on the Node side and will NOT be accessible from the browser bundle.

# Application version, surfaced in the UI for debugging / support.
VITE_APP_VERSION=0.1.0

# Base URL used when serving the built site. Must match the GitHub Pages
# repository path (e.g. /framer-motion-score-float-demo/) or `/` if you are
# hosting on a custom domain or at the root of a server.
VITE_BASE_URL=/framer-motion-score-float-demo/
